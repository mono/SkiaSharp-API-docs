    {
      "memberType": "type",
      "docId": null,
      "fields": {
        "remarksRequired": true,
        "remarks": "<format type=\"text/markdown\"><![CDATA[\n## Remarks\n\n<see cref=\"T:SkiaSharp.SKColorspacePrimariesCicp\" /> identifies the color primaries of a color space using the CICP system defined in ITU-T H.273 / ISO 23091-2. These values correspond to the `colour_primaries` field in CICP metadata.\n\nUse this enum with <see cref=\"M:SkiaSharp.SKColorSpace.CreateCicp(SkiaSharp.SKColorspacePrimariesCicp,SkiaSharp.SKColorspaceTransferFnCicp)\" /> to create a color space from CICP parameters.\n\n## Examples\n\n```csharp\nvar colorSpace = SKColorSpace.CreateCicp(\n    SKColorspacePrimariesCicp.Rec709,\n    SKColorspaceTransferFnCicp.Rec709);\n```\n]]></format>",
        "summary": "Specifies CICP (Coding-Independent Code Points) color primaries as defined in ITU-T H.273."
      }
    },
