    {
      "memberType": "type",
      "docId": null,
      "fields": {
        "remarksRequired": true,
        "remarks": "<format type=\"text/markdown\"><![CDATA[\n## Remarks\n\n<see cref=\"T:SkiaSharp.SKColorspaceTransferFnCicp\" /> identifies the opto-electrical transfer function of a color space using the CICP system defined in ITU-T H.273 / ISO 23091-2. These values correspond to the `transfer_characteristics` field in CICP metadata.\n\nUse this enum with <see cref=\"M:SkiaSharp.SKColorSpace.CreateCicp(SkiaSharp.SKColorspacePrimariesCicp,SkiaSharp.SKColorspaceTransferFnCicp)\" /> to create a color space from CICP parameters.\n\n## Examples\n\n```csharp\nvar colorSpace = SKColorSpace.CreateCicp(\n    SKColorspacePrimariesCicp.Rec2020,\n    SKColorspaceTransferFnCicp.Pq);\n```\n]]></format>",
        "summary": "Specifies CICP (Coding-Independent Code Points) transfer characteristics as defined in ITU-T H.273."
      }
    },
